# Database Connection
# Format: postgresql://username:password@localhost/database_name
DATABASE_URL=postgresql://user:password@localhost/mocavi_db

# Google Gemini API Key
# Get your API key from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# JWT Secret - Generate a secure random string for production
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-change-this-in-production

# JWT Token expiration time (minutes)
JWT_EXPIRATION_MINUTES=1440

# Environment (development or production)
ENVIRONMENT=development

# Orígenes permitidos para CORS (separados por coma).
#   Local:       http://localhost:3000,http://127.0.0.1:3000
#   Producción:  añade la URL de tu frontend en Vercel (https://tuapp.vercel.app)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
